# --- Resend (order confirmation email) ---
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Optional. Must be a verified sender/domain on your Resend account.
# The shared onboarding@resend.dev sender only delivers to the email you
# signed up to Resend with — verify your own domain to email real customers.
RESEND_FROM="SkinSnap <onboarding@resend.dev>"

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID from Events Manager, e.g. 1234567890123456
NEXT_PUBLIC_FB_PIXEL_ID=
